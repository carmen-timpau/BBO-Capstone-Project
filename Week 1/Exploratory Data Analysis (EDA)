    for v, s in zip(f4_min_max_y_vals, sizes)]

legend = function4_plot.legend(handles=handles, title="Size scale (y)", loc="upper left", fontsize = 15, labelspacing=3.0, handletextpad=2.0, handlelength=0.5)
legend.get_title().set_fontsize(15)
legend._legend_title_box._text.set_va("top")
