#Creating a dictionary for the initial datasets of all 8 functions
data = {}

#Loading all initial data


#Printing all initial data (to 6 decimal places) provided for all functions

for i in range (1,9):
    x = data[f"function_{i}"]["x"]
    y = data[f"function_{i}"]["y"]

    print(f"\nFunction {i} initial datapoints are:\n")
    
    for j, (x,y) in enumerate(zip(x, y), start = 1):
        print(f"{j}. ({x}, {y:.6f})")


#Computing statistical analysis of all functions' initial outputs

for i in range (1,9):
    min_value = data[f"function_{i}"]["y"].min()
    max_value = data[f"function_{i}"]["y"].max()
    mean = data[f"function_{i}"]["y"].mean()
    std = data[f"function_{i}"]["y"].std()
    print(f"\nStatistical analysis of Function {i}:")
    print("-" * 35)
    print(f"\nMinimum value = {min_value:.6f}")
    print(f"Maximum value = {max_value:.6f}")
    print(f"Standard deviation = {std:.6f}")
    print(f"Mean = {mean:.6f}")


#Plotting Function 1's Initial Datapoints in a 3D Scatter Plot
