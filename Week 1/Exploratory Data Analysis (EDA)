#Plotting Function 4's Initial Datapoints in a 5D Scatter Plot (3D Position + Colour + Size Encoding)
fig = plt.figure(figsize=(20, 15))
function4_y = data["function_4"]["y"]*(-1) #Turning values of Function 4 outputs into positive values (overall multiplication with (-1)) to turn this into a maximisation problem 

function4_plot = fig.add_subplot(111, projection='3d')
f4p = function4_plot.scatter(data["function_4"]["x"][:,0],
                       data["function_4"]["x"][:,1], 
                       data["function_4"]["x"][:,2], 
                       c = data["function_4"]["x"][:,3], #4th dimension -> colour
                       s = function4_y*80, cmap = 'viridis') #5th dimension -> size

function4_plot.tick_params(labelsize = 15)
vmax = np.max(np.abs(data["function_4"]["x"][:,3]))
